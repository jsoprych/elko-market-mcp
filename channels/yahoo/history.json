{
  "name": "yahoo_history",
  "description": "OHLCV price history from Yahoo Finance. Returns CSV rows: Timestamp,Date,Open,High,Low,Close,AdjClose,Volume.",
  "source": "yahoo",
  "category": "equity",
  "schema": {
    "type": "object",
    "properties": {
      "symbol":   {"type": "string", "description": "Ticker symbol", "placeholder": "AAPL"},
      "period":   {"type": "string", "description": "Rolling window (overridden by from/to)", "enum": ["1d","5d","1mo","3mo","6mo","1y","2y","5y","10y","ytd","max"], "default": "1mo"},
      "interval": {"type": "string", "description": "Bar size", "enum": ["1m","5m","15m","30m","1h","1d","1wk","1mo"], "default": "1d"},
      "from":     {"type": "string", "description": "Start date (overrides period)", "placeholder": "2024-01-01"},
      "to":       {"type": "string", "description": "End date (defaults to today)",  "placeholder": "2024-12-31"}
    },
    "required": ["symbol"]
  },
  "result_format": "csv",
  "request": {
    "base_url": "https://query1.finance.yahoo.com/v8/finance/chart",
    "headers": {
      "User-Agent": "Mozilla/5.0 (compatible; elko-market-mcp/1.0)"
    },
    "ttl": "1h"
  },
  "response": {
    "extractor": "yahoo_chart_ohlcv"
  }
}
