{
  "name": "fdic_bank_search",
  "description": "Search FDIC-insured banks by name. Returns institution summary: cert number, name, city, state, status, asset size.",
  "source": "fdic",
  "category": "banking",
  "schema": {
    "type": "object",
    "properties": {
      "name":  {"type": "string",  "description": "Bank name (partial match)",               "placeholder": "First National"},
      "state": {"type": "string",  "description": "Two-letter state abbreviation",           "placeholder": "NY"},
      "limit": {"type": "integer", "description": "Max results (default 10, max 50)",        "default": 10, "minimum": 1, "maximum": 50}
    }
  },
  "result_format": "table",
  "options": {
    "field_case": "upper"
  },
  "request": {
    "base_url": "https://api.fdic.gov/banks",
    "headers": {
      "Accept": "application/json"
    },
    "ttl": "24h"
  },
  "response": {
    "extractor": "fdic_bank_search"
  }
}
