{
  "name": "fdic_bank_financials",
  "description": "Financial summary for an FDIC-insured bank by certificate number. Returns assets, deposits, equity, net income, capital ratios.",
  "source": "fdic",
  "category": "banking",
  "schema": {
    "type": "object",
    "properties": {
      "cert": {"type": "string",  "description": "FDIC certificate number (from fdic_bank_search)", "placeholder": "3511"},
      "year": {"type": "integer", "description": "Report year (default: most recent)", "placeholder": "2023", "minimum": 1992}
    },
    "required": ["cert"]
  },
  "result_format": "sections",
  "options": {
    "field_case": "upper"
  },
  "request": {
    "base_url": "https://api.fdic.gov/banks",
    "headers": {
      "Accept": "application/json"
    },
    "ttl": "24h"
  },
  "response": {
    "extractor": "fdic_bank_financials"
  }
}
