{
  "name": "treasury_yields",
  "description": "US Treasury yield curve from fiscaldata.treasury.gov. Returns daily rates for all tenors (1mo\u201330y).",
  "source": "treasury",
  "category": "rates",
  "schema": {
    "type": "object",
    "properties": {
      "from":   {"type": "string",  "description": "Start date YYYY-MM-DD (default: 30 days ago)"},
      "to":     {"type": "string",  "description": "End date YYYY-MM-DD (default: today)"},
      "latest": {"type": "boolean", "description": "Return only the most recent available date"}
    }
  },
  "request": {
    "base_url": "https://api.fiscaldata.treasury.gov",
    "headers": {
      "Accept": "application/json"
    },
    "ttl": "6h"
  },
  "response": {
    "extractor": "treasury_yields"
  }
}
