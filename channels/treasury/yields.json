{
  "name": "treasury_yields",
  "description": "US Treasury average interest rates from fiscaldata.treasury.gov. Returns rates by security type.",
  "source": "treasury",
  "category": "rates",
  "schema": {
    "type": "object",
    "properties": {
      "from":   {"type": "string", "format": "date", "description": "Start date (default: 30 days ago)"},
      "to":     {"type": "string", "format": "date", "description": "End date (default: today)"},
      "latest": {"type": "boolean", "description": "Return only the most recent available date"}
    }
  },
  "result_format": "table",
  "request": {
    "base_url": "https://api.fiscaldata.treasury.gov",
    "headers": {
      "Accept": "application/json"
    },
    "ttl": "6h"
  },
  "response": {
    "extractor": "treasury_yields"
  }
}
