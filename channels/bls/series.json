{
  "name": "bls_series",
  "description": "Bureau of Labor Statistics time series data. Well-known series: CUUR0000SA0 (CPI-U All Items NSA), CUSR0000SA0 (CPI-U SA), LNS14000000 (Unemployment Rate SA), CES0000000001 (Total Nonfarm Payrolls), WPUFD49104 (PPI Final Demand). Use BLS series IDs directly for other series.",
  "source": "bls",
  "category": "macro",
  "schema": {
    "type": "object",
    "properties": {
      "series_id":  {"type": "string", "description": "BLS series ID", "placeholder": "CUUR0000SA0",
                     "examples": ["CUUR0000SA0","CUSR0000SA0","LNS14000000","CES0000000001","WPUFD49104"]},
      "start_year": {"type": "string", "description": "Start year YYYY (default: 5 years ago)", "placeholder": "2020"},
      "end_year":   {"type": "string", "description": "End year YYYY (default: current year)",   "placeholder": "2026"}
    },
    "required": ["series_id"]
  },
  "result_format": "table",
  "chart": {"type": "line", "x": "Year", "y": "Value"},
  "request": {
    "base_url": "https://api.bls.gov",
    "headers": {
      "Accept": "application/json"
    },
    "ttl": "12h"
  },
  "response": {
    "extractor": "bls_series"
  }
}
