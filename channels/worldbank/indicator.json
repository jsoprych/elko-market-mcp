{
  "name": "worldbank_indicator",
  "description": "World Bank macroeconomic indicator for one or more countries. Common indicators: NY.GDP.MKTP.CD (GDP current US$), NY.GDP.PCAP.CD (GDP per capita), NY.GDP.MKTP.KD.ZG (GDP growth annual %), FP.CPI.TOTL.ZG (Inflation consumer prices), SL.UEM.TOTL.ZS (Unemployment rate), NE.TRD.GNFS.ZS (Trade % of GDP), GC.DOD.TOTL.GD.ZS (Central govt debt), SP.POP.TOTL (Population).",
  "source": "worldbank",
  "category": "macro",
  "schema": {
    "type": "object",
    "properties": {
      "country":   {"type": "string",  "description": "ISO 3166-1 alpha-2 or alpha-3, or 'all'", "placeholder": "US",
                    "examples": ["US","GB","CHN","DEU","JPN","all"]},
      "indicator": {"type": "string",  "description": "World Bank indicator code", "placeholder": "NY.GDP.MKTP.CD",
                    "examples": ["NY.GDP.MKTP.CD","NY.GDP.PCAP.CD","NY.GDP.MKTP.KD.ZG","FP.CPI.TOTL.ZG","SL.UEM.TOTL.ZS","SP.POP.TOTL"]},
      "from_year": {"type": "integer", "description": "Start year (default: 10 years ago)", "placeholder": "2015", "minimum": 1960},
      "to_year":   {"type": "integer", "description": "End year (default: current year)",   "placeholder": "2024", "minimum": 1960}
    },
    "required": ["country", "indicator"]
  },
  "request": {
    "base_url": "https://api.worldbank.org",
    "headers": {
      "Accept": "application/json"
    },
    "ttl": "24h"
  },
  "response": {
    "extractor": "worldbank_indicator"
  }
}
