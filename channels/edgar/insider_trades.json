{
  "name": "edgar_insider_trades",
  "description": "SEC Form 4 insider transactions for a US-listed company. Shows open-market buys and sells by officers (CEO, CFO, etc.), directors, and >10% shareholders. Filed within 2 business days of each transaction. Use types=all to include option exercises, awards, and gifts.",
  "source": "edgar",
  "category": "equity",
  "schema": {
    "type": "object",
    "properties": {
      "symbol": {"type": "string",  "description": "Ticker symbol",                                                      "placeholder": "AAPL"},
      "months": {"type": "integer", "description": "Lookback period in months (default 12, max 36)",                     "default": 12, "minimum": 1, "maximum": 36},
      "types":  {"type": "string",  "description": "trade = open-market buys/sells only (default); all = every type",   "default": "trade", "enum": ["trade", "all"]},
      "limit":  {"type": "integer", "description": "Max transactions to return (default 30, max 100)",                   "default": 30, "minimum": 1, "maximum": 100}
    },
    "required": ["symbol"]
  },
  "result_format": "table",
  "request": {
    "base_url": "https://data.sec.gov",
    "headers": {
      "User-Agent": "elko-market-mcp/1.0 contact@localhost",
      "Accept": "application/json, application/xml, text/xml"
    },
    "env_headers": {
      "User-Agent": "SEC_USER_AGENT"
    },
    "ttl": "4h"
  },
  "response": {
    "extractor": "edgar_insider_trades"
  }
}
