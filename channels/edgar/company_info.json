{
  "name": "edgar_company_info",
  "description": "Company metadata from SEC EDGAR: name, SIC industry, state of incorporation, fiscal year end, filer category.",
  "source": "edgar",
  "category": "equity",
  "schema": {
    "type": "object",
    "properties": {
      "symbol": {"type": "string", "description": "Ticker symbol (US-listed)", "placeholder": "MSFT"}
    },
    "required": ["symbol"]
  },
  "result_format": "kv",
  "request": {
    "base_url": "https://data.sec.gov",
    "headers": {
      "User-Agent": "elko-market-mcp/1.0 contact@localhost",
      "Accept": "application/json, application/atom+xml, text/html"
    },
    "env_headers": {
      "User-Agent": "SEC_USER_AGENT"
    },
    "ttl": "24h"
  },
  "response": {
    "extractor": "edgar_company_info"
  }
}
